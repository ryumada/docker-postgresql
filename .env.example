# --- Docker Compose Settings ---
# Postgres official image tag to deploy (e.g. 15, 16, 15-alpine)
POSTGRES_IMAGE_VERSION=15

# Memory allocated to the container's /dev/shm. Should be large enough for heavy parallelism.
# Higher: Allows more parallel workers and intensive memory operations without crashing.
# Default: 64m. Recommended: 128mb or 256mb for production.
POSTGRES_SHM_SIZE=128mb

# Name of the external docker networks your application connects over.
# Support multiple networks by separating them with a comma (e.g., net1,net2).
EXTERNAL_NETWORK_NAMES=my_external_network

# The hostname the database will be known as within the Docker network.
POSTGRES_HOST=db

# --- Initial Setup & Ownership ---
# Name for the primary maintenance (superuser) and its default database.
# Default: postgres.
MAINTENANCE_USER=postgres

# --- PostgreSQL Performance Tuning ---
# NOTE: The defaults below are tuned for a standard VM with 4GB-8GB RAM & 2-4 vCPUs.

# --- Connections and Memory ---
# Maximum number of concurrent connections to the database server.
# Higher: Allows more apps to connect simultaneously. (Uses more RAM & Semaphore resources).
# Lower: Prevents RAM starvation under heavy connection floods.
# Recommendation: Keep <= 200 unless using a connection pooler like PgBouncer.
POSTGRES_MAX_CONNECTIONS=100

# Dedicated memory for PostgreSQL to cache data.
# Higher: More data fits in RAM, massive read speedups. If too high, OS has no RAM for its own disk cache.
# Recommendation: Set to 25% of total server RAM. (e.g., 1GB for a 4GB server, 4GB for a 16GB server).
POSTGRES_SHARED_BUFFERS=1GB

# Estimate of how much memory is available for disk caching by the OS and within PostgreSQL itself.
# Higher: Tells the planner to use indexes aggressively instead of slow sequential scans.
# Recommendation: Set to 50% - 75% of total server RAM. (e.g., 3GB for a 4GB server).
POSTGRES_EFFECTIVE_CACHE_SIZE=3GB

# Maximum memory used for maintenance operations (VACUUM, CREATE INDEX, ALTER TABLE).
# Higher: Faster backups, index creations, and vacuuming. Too high wastes RAM since it's rarely running all the time.
# Recommendation: 256MB for 4GB RAM / 1GB for 16GB RAM.
POSTGRES_MAINTENANCE_WORK_MEM=256MB

# Base memory used per sort/hash operation per active query connection.
# Higher: Prevents complex queries (ORDER BY, JOIN) from writing temporary files to disk, greatly improving speed.
# Danger: If set to 64MB and you have 100 queries doing complex sorts simultaneously, it will use 6.4GB of RAM!
# Recommendation: 16MB for most standard workloads. 64MB+ if heavy analytics/reporting.
POSTGRES_WORK_MEM=16MB


# --- Write-Ahead Log (WAL) & Checkpoints ---
# Target ratio of a checkpoint interval to spread out disk writes.
# Higher (0.9): Spreads writes out smoothly, avoiding sudden I/O spikes (Freezing). Always use 0.9.
POSTGRES_CHECKPOINT_COMPLETION_TARGET=0.9

# How much WAL data to buffer in RAM before flushing to disk.
# Higher: Improves write performance during massive insert waves.
# Recommendation: Typically -1 (auto sizes it to ~3% of shared_buffers) or 16MB.
POSTGRES_WAL_BUFFERS=16MB

# Minimum and Maximum size of the Write-Ahead Log to keep on disk.
# Higher MAX: Drastically improves bulk data ingestion speed by delaying heavy disk flushing. Uses more disk space.
# Recommendation: 1GB MIN / 4GB MAX for decent write-heavy apps. Size down if extremely low on SSD space.
POSTGRES_MIN_WAL_SIZE=1GB
POSTGRES_MAX_WAL_SIZE=4GB


# --- Query Tuning & Planner ---
# How much data the planner analyzes when collecting statistics on tables.
# Higher: Better, smarter query plans (especially on large/complex tables). Slower ANALYZE execution.
# Recommendation: 100 is default. 500-1000 for massive/complex report queries.
POSTGRES_DEFAULT_STATISTICS_TARGET=100

# The planner's expected cost of a non-sequentially-fetched disk page.
# Higher (4.0): Tells DB you use slow spinning HDDs.
# Lower (1.1): Tells DB you use fast SSDs. Encourages aggressive, fast index usage.
# Recommendation: 1.1 for SSD/Cloud storage. 4.0 for old spinning disks.
POSTGRES_RANDOM_PAGE_COST=1.1

# The number of concurrent disk I/O operations the underlying subsystem can handle.
# Higher: Tells Postgres an SSD can handle hundreds of parallel reads, vastly speeding up bitmap heap scans.
# Recommendation: 200 for SSD. 0 or 1 for HDDs.
POSTGRES_EFFECTIVE_IO_CONCURRENCY=200


# --- Worker Processes (CPU Parallelism) ---
# Maximum number of background worker processes the system can support.
# Higher: Allows heavier analytics and parallel operations.
# Recommendation: Set equal to the number of physical CPU cores on the VM (e.g., 4 or 8).
POSTGRES_MAX_WORKER_PROCESSES=4

# Maximum number of workers that can be used by a SINGLE query gather node.
# Higher: A single complex query can utilize multiple CPU cores to finish faster.
# Warning: Setting too high means a single heavy query can monopolize all CPU cores, starving others.
# Recommendation: Usually 2 or 4. Do not exceed max_worker_processes.
POSTGRES_MAX_PARALLEL_WORKERS_PER_GATHER=2


# --- Standard PostgreSQL Settings ---
# Which IP addresses the server listens on for client connections.
# Recommendation: '*' to allow connections from Docker networks.
POSTGRES_LISTEN_ADDRESSES='*'

# The time zone used for timestamps written to the server log.
# Recommendation: 'UTC' is best for system logs.
POSTGRES_LOG_TIMEZONE='UTC'

# Sets the display format for date and time values.
# Recommendation: 'iso, mdy' is standard.
POSTGRES_DATESTYLE='iso, mdy'

# Sets the time zone for the database session.
# Recommendation: 'UTC' to keep data consistent across global deployments.
POSTGRES_TIMEZONE='UTC'

# Specifies the dynamic shared memory implementation the server should use.
# Recommendation: 'posix' is standard for modern Linux/Docker.
POSTGRES_DYNAMIC_SHARED_MEMORY_TYPE=posix


# --- Connection Management & Timeouts ---
# Terminate any session that has been idle (no transaction) for the specified time.
# Recommendation: 1h or 1d to clean up abandoned connections. 0 to disable.
POSTGRES_IDLE_SESSION_TIMEOUT=1h

# Terminate any session that has been idle while within an open transaction.
# CRITICAL: Prevents table bloat and locking issues from forgotten transactions.
# Recommendation: 5min or 10min for production.
POSTGRES_IDLE_IN_TRANSACTION_SESSION_TIMEOUT=5min

# Abort any statement that takes more than the specified amount of time.
# Recommendation: 10min to catch runaway queries. 0 to disable.
# Default set to 2 hours to allow big report queries
POSTGRES_STATEMENT_TIMEOUT=2h


# --- Performance Auditing & Logging ---
# Log any statement that takes longer than this duration (in milliseconds).
# Recommendation: 250 or 500 to catch slow queries. -1 to disable.
POSTGRES_LOG_MIN_DURATION_STATEMENT=500


# --- Resource Usage & Internals ---
# Maximum amount of memory used for temporary buffers in each session.
# Recommendation: 32MB or 64MB for better temp table performance.
POSTGRES_TEMP_BUFFERS=32MB

# Maximum safe depth of the server's execution stack.
# Recommendation: 2MB is standard. Ensure it matches OS 'ulimit -s'.
POSTGRES_MAX_STACK_DEPTH=2MB

# Amount of memory reserved to store the text of the currently executing query.
# Recommendation: 2048 or 4096 if you have very long/complex SQL queries.
POSTGRES_TRACK_ACTIVITY_QUERY_SIZE=2048


# --- WAL & Replication ---
# Controls how much information is written to the WAL.
# Recommendation: 'replica' to support standbys and backups.
POSTGRES_WAL_LEVEL=replica

# Specifies whether transaction commit will wait for WAL records to be flushed to disk.
# Recommendation: 'on' for maximum data safety. 'off' for massive speed boost at risk of data loss on crash.
POSTGRES_SYNCHRONOUS_COMMIT=on


# --- Autovacuum Tuning ---
# Enables the autovacuum daemon. Highly recommended for production.
# Recommendation: 'on' to keep tables healthy and prevent bloat.
POSTGRES_AUTOVACUUM=on

# Maximum number of autovacuum worker processes that can run simultaneously.
# Recommendation: 3 to 5. Increase for databases with hundreds of active tables.
POSTGRES_AUTOVACUUM_MAX_WORKERS=3

# The delay between autovacuum runs on a given database.
# Recommendation: 20s or 30s for more proactive cleaning. Default is 1min.
POSTGRES_AUTOVACUUM_NAPTIME=20s

# The fraction of table size that triggers a vacuum or analyze.
# Recommendation: 0.1 or 0.2. Lower (0.05) for very large tables to trigger cleaning sooner.
POSTGRES_AUTOVACUUM_VACUUM_SCALE_FACTOR=0.2
POSTGRES_AUTOVACUUM_ANALYZE_SCALE_FACTOR=0.1

# The cost delay for autovacuum when it exceeds the cost limit.
# Recommendation: 2ms to 10ms. Lower is faster but uses more I/O.
POSTGRES_AUTOVACUUM_VACUUM_COST_DELAY=10ms


# --- Extensions & Libraries ---
# Shared libraries to be preloaded at server start.
# Recommendation: 'pg_stat_statements' is essential for performance monitoring.
POSTGRES_SHARED_PRELOAD_LIBRARIES='pg_stat_statements'
